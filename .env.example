# ─────────────────────────────────────────────────────────
#  E2E Copilot Agents – Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file to source control.
# ─────────────────────────────────────────────────────────

# SQL Server Connection
# For default instance, use DB_SERVER=localhost and DB_PORT=1433
# For named instance (e.g. SQL Express), use DB_SERVER=localhost\SQLEXPRESS and comment out or omit DB_PORT to allow dynamic port resolution.
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=YourDatabaseName

# For SQL Server Authentication:
DB_USER=sa
DB_PASSWORD=YourStrongPassword!

# For Windows Authentication (Trusted Connection / SSO):
# Set DB_TRUSTED_CONNECTION=true (and still provide DB_SERVER instance/port as needed)
# If true, it uses the native 'msnodesqlv8' driver using the logged-in Windows user context.
# Make sure to run 'npm install' in the 'mcp-server' folder first.
# DB_TRUSTED_CONNECTION=true
#
# Optional: ODBC driver name to use for Windows Authentication.
# Defaults to "ODBC Driver 17 for SQL Server". If you have ODBC Driver 18 installed, you can set it here:
# DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# Optional: Encrypt connection (recommended for production)
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Output directory for generated Word documents
OUTPUT_DIR=../output

# Test schema (used by unit-test-agent for isolated test deployments)
DB_TEST_SCHEMA=dbo_test
